{
  "$schema": "https://raw.githubusercontent.com/nicegoodthings/tauri-schema-dev/main/tauri.conf.schema.json",
  "productName": "Orivraa",
  "version": "0.1.0",
  "identifier": "com.orivraa.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../web && pnpm dev",
    "beforeBuildCommand": "cd ../web && npx cross-env TAURI_BUILD=1 pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Orivraa — Jewellery Business Suite",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Orivraa Desktop"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.orivraa.com https://*.orivraa.com wss://api.orivraa.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "Hindi"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "publisher": "Orivraa",
    "shortDescription": "Jewellery business management desktop application",
    "longDescription": "Orivraa Desktop provides offline-capable CRM, inventory management, invoicing, and AI-powered features for jewellery sellers.",
    "copyright": "© 2026 Orivraa. All rights reserved."
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/aakash-priyadarshi/gold-shop-app/releases/latest/download/latest.json"
      ],
      "dialog": true
    },
    "shell": {
      "open": true
    }
  }
}

{
  "identifier": "com.orivraa.desktop",
  "description": "Orivraa desktop app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:default",
    "notification:default",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "autostart:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}

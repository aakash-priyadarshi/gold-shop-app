<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Confirmation</title>
  <style>
    body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; background-color: #f5f5f5; color: #333333; line-height: 1.6; }
    .wrapper { width: 100%; background-color: #f5f5f5; padding: 40px 0; }
    .main { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05); }
    .header { background: linear-gradient(135deg, #d97706 0%, #b45309 100%); padding: 30px 40px; text-align: center; }
    .logo { font-size: 28px; font-weight: bold; color: #ffffff; text-decoration: none; }
    .content { padding: 40px; }
    .footer { background-color: #f9fafb; padding: 30px 40px; text-align: center; border-top: 1px solid #e5e7eb; }
    .footer p { margin: 5px 0; font-size: 13px; color: #6b7280; }
    .footer a { color: #d97706; text-decoration: none; }
    h1 { font-size: 24px; font-weight: 600; color: #111827; margin: 0 0 20px 0; }
    h2 { font-size: 18px; font-weight: 600; color: #374151; margin: 30px 0 15px 0; }
    p { margin: 0 0 16px 0; color: #4b5563; }
    .button { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #d97706 0%, #b45309 100%); color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; margin: 20px 0; }
    .success-box { background-color: #ecfdf5; border-left: 4px solid #10b981; padding: 16px 20px; margin: 20px 0; border-radius: 0 8px 8px 0; }
    .order-header { background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 8px; padding: 20px; margin: 20px 0; text-align: center; }
    .order-number { font-size: 14px; color: #92400e; text-transform: uppercase; letter-spacing: 1px; }
    .order-id { font-size: 24px; font-weight: bold; color: #78350f; margin-top: 5px; }
    table.order-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
    table.order-table th { background-color: #f3f4f6; padding: 12px 16px; text-align: left; font-size: 13px; font-weight: 600; color: #374151; text-transform: uppercase; }
    table.order-table td { padding: 12px 16px; border-bottom: 1px solid #e5e7eb; font-size: 14px; }
    table.order-table tr:last-child td { border-bottom: none; }
    .total-row { background-color: #fef3c7; font-weight: 600; }
    .address-box { background-color: #f9fafb; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .address-title { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #6b7280; margin-bottom: 8px; }
    .address-text { color: #374151; font-size: 14px; }
    .divider { height: 1px; background-color: #e5e7eb; margin: 30px 0; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="main">
      <div class="header">
        <a href="{{appUrl}}" class="logo">✨ {{appName}}</a>
      </div>
      <div class="content">
        <h1>Order Confirmed! 🎉</h1>
        
        <p>Hi {{customerName}},</p>
        
        <div class="success-box">
          <strong>✅ Thank you for your order!</strong>
          <p style="margin: 8px 0 0 0; font-size: 14px;">
            Your order has been received and is being processed by <strong>{{shopName}}</strong>.
          </p>
        </div>
        
        <div class="order-header">
          <div class="order-number">Order Number</div>
          <div class="order-id">#{{orderNumber}}</div>
        </div>
        
        <h2>Order Details</h2>
        
        <table class="order-table">
          <thead>
            <tr>
              <th>Item</th>
              <th style="text-align: center;">Qty</th>
              <th style="text-align: right;">Price</th>
            </tr>
          </thead>
          <tbody>
            {{#each items}}
            <tr>
              <td>{{this.name}}</td>
              <td style="text-align: center;">{{this.quantity}}</td>
              <td style="text-align: right;">{{formatCurrency this.price ../currency}}</td>
            </tr>
            {{/each}}
            <tr>
              <td colspan="2" style="text-align: right;">Subtotal</td>
              <td style="text-align: right;">{{formatCurrency subtotal currency}}</td>
            </tr>
            <tr>
              <td colspan="2" style="text-align: right;">Shipping</td>
              <td style="text-align: right;">{{formatCurrency shipping currency}}</td>
            </tr>
            {{#if tax}}
            <tr>
              <td colspan="2" style="text-align: right;">Tax</td>
              <td style="text-align: right;">{{formatCurrency tax currency}}</td>
            </tr>
            {{/if}}
            <tr class="total-row">
              <td colspan="2" style="text-align: right;"><strong>Total</strong></td>
              <td style="text-align: right;"><strong>{{formatCurrency total currency}}</strong></td>
            </tr>
          </tbody>
        </table>
        
        <div class="address-box">
          <div class="address-title">Shipping Address</div>
          <div class="address-text">{{shippingAddress}}</div>
        </div>
        
        <div style="text-align: center;">
          <a href="{{appUrl}}/dashboard/customer/orders" class="button">Track Order</a>
        </div>
        
        <div class="divider"></div>
        
        <p style="font-size: 14px; color: #6b7280;">
          Questions about your order? Contact the seller or reach us at 
          <a href="mailto:{{supportEmail}}" style="color: #d97706;">{{supportEmail}}</a>
        </p>
      </div>
      <div class="footer">
        <p>© {{year}} {{appName}}. All rights reserved.</p>
        <p><a href="{{appUrl}}">Visit Website</a> • <a href="mailto:{{supportEmail}}">Contact Support</a></p>
      </div>
    </div>
  </div>
</body>
</html>

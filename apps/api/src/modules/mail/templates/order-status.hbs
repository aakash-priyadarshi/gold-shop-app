<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Status Update</title>
  <style>
    body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; background-color: #f5f5f5; color: #333333; line-height: 1.6; }
    .wrapper { width: 100%; background-color: #f5f5f5; padding: 40px 0; }
    .main { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05); }
    .header { background: linear-gradient(135deg, #d97706 0%, #b45309 100%); padding: 30px 40px; text-align: center; }
    .logo { font-size: 28px; font-weight: bold; color: #ffffff; text-decoration: none; }
    .content { padding: 40px; }
    .footer { background-color: #f9fafb; padding: 30px 40px; text-align: center; border-top: 1px solid #e5e7eb; }
    .footer p { margin: 5px 0; font-size: 13px; color: #6b7280; }
    .footer a { color: #d97706; text-decoration: none; }
    h1 { font-size: 24px; font-weight: 600; color: #111827; margin: 0 0 20px 0; }
    p { margin: 0 0 16px 0; color: #4b5563; }
    .button { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #d97706 0%, #b45309 100%); color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; margin: 20px 0; }
    .status-box { border-radius: 8px; padding: 20px; margin: 20px 0; text-align: center; }
    .status-processing { background-color: #dbeafe; border: 2px solid #3b82f6; }
    .status-shipped { background-color: #fef3c7; border: 2px solid #f59e0b; }
    .status-delivered { background-color: #d1fae5; border: 2px solid #10b981; }
    .status-cancelled { background-color: #fee2e2; border: 2px solid #ef4444; }
    .status-label { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
    .status-value { font-size: 24px; font-weight: bold; }
    .order-ref { background-color: #f9fafb; border-radius: 8px; padding: 15px; margin: 20px 0; }
    .info-box { background-color: #f0f9ff; border-left: 4px solid #0284c7; padding: 16px 20px; margin: 20px 0; border-radius: 0 8px 8px 0; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="main">
      <div class="header">
        <a href="{{appUrl}}" class="logo">✨ {{appName}}</a>
      </div>
      <div class="content">
        <h1>Order Status Update</h1>
        
        <p>Hi {{customerName}},</p>
        
        <p>Your order status has been updated:</p>
        
        <div class="order-ref">
          <span style="color: #6b7280; font-size: 14px;">Order Number:</span>
          <strong style="font-size: 18px; color: #111827; margin-left: 10px;">#{{orderNumber}}</strong>
        </div>
        
        <div class="status-box {{#eq status 'PROCESSING'}}status-processing{{/eq}}{{#eq status 'SHIPPED'}}status-shipped{{/eq}}{{#eq status 'DELIVERED'}}status-delivered{{/eq}}{{#eq status 'CANCELLED'}}status-cancelled{{/eq}}">
          <div class="status-label">Current Status</div>
          <div class="status-value">{{status}}</div>
        </div>
        
        <p>{{statusMessage}}</p>
        
        {{#if trackingNumber}}
        <div class="info-box">
          <strong>📦 Tracking Information</strong>
          <p style="margin: 8px 0 0 0; font-size: 14px;">
            Tracking Number: <strong>{{trackingNumber}}</strong>
          </p>
          {{#if trackingUrl}}
          <p style="margin: 8px 0 0 0;">
            <a href="{{trackingUrl}}" style="color: #d97706;">Track your package →</a>
          </p>
          {{/if}}
        </div>
        {{/if}}
        
        <div style="text-align: center;">
          <a href="{{appUrl}}/dashboard/customer/orders" class="button">View Order Details</a>
        </div>
      </div>
      <div class="footer">
        <p>© {{year}} {{appName}}. All rights reserved.</p>
        <p><a href="{{appUrl}}">Visit Website</a> • <a href="mailto:{{supportEmail}}">Contact Support</a></p>
      </div>
    </div>
  </div>
</body>
</html>

<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Quote Request</title>
  <style>
    body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; background-color: #f5f5f5; color: #333333; line-height: 1.6; }
    .wrapper { width: 100%; background-color: #f5f5f5; padding: 40px 0; }
    .main { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05); }
    .header { background: linear-gradient(135deg, #d97706 0%, #b45309 100%); padding: 30px 40px; text-align: center; }
    .logo { font-size: 28px; font-weight: bold; color: #ffffff; text-decoration: none; }
    .content { padding: 40px; }
    .footer { background-color: #f9fafb; padding: 30px 40px; text-align: center; border-top: 1px solid #e5e7eb; }
    .footer p { margin: 5px 0; font-size: 13px; color: #6b7280; }
    .footer a { color: #d97706; text-decoration: none; }
    h1 { font-size: 24px; font-weight: 600; color: #111827; margin: 0 0 20px 0; }
    p { margin: 0 0 16px 0; color: #4b5563; }
    .button { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #d97706 0%, #b45309 100%); color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; margin: 20px 0; }
    .rfq-banner { background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); border-radius: 12px; padding: 30px; text-align: center; margin: 20px 0; border: 2px solid #3b82f6; }
    .rfq-details { background-color: #f9fafb; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .detail-row { display: flex; padding: 10px 0; border-bottom: 1px solid #e5e7eb; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { width: 40%; color: #6b7280; font-size: 14px; }
    .detail-value { width: 60%; color: #111827; font-weight: 500; font-size: 14px; }
    .info-box { background-color: #f0f9ff; border-left: 4px solid #0284c7; padding: 16px 20px; margin: 20px 0; border-radius: 0 8px 8px 0; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="main">
      <div class="header">
        <a href="{{appUrl}}" class="logo">✨ {{appName}}</a>
      </div>
      <div class="content">
        <h1>📝 New Quote Request</h1>
        
        <p>Hi {{shopOwnerName}},</p>
        
        <p>You've received a new request for quote (RFQ) from a customer.</p>
        
        <div class="rfq-banner">
          <div style="font-size: 32px; margin-bottom: 10px;">✨</div>
          <div style="font-size: 14px; color: #1e40af; text-transform: uppercase; letter-spacing: 1px;">Quote Request</div>
          <div style="font-size: 24px; font-weight: bold; color: #1e3a8a; margin-top: 5px;">{{rfqNumber}}</div>
        </div>
        
        <div class="rfq-details">
          <div class="detail-row">
            <span class="detail-label">Customer</span>
            <span class="detail-value">{{customerName}}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Material</span>
            <span class="detail-value">{{material}}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Estimated Weight</span>
            <span class="detail-value">{{weight}}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Description</span>
            <span class="detail-value">{{itemDescription}}</span>
          </div>
        </div>
        
        <div class="info-box">
          <strong>💡 Tip</strong>
          <p style="margin: 8px 0 0 0; font-size: 14px;">
            Respond to quote requests promptly to improve your shop's reputation and win more customers.
          </p>
        </div>
        
        <div style="text-align: center;">
          <a href="{{dashboardUrl}}" class="button">View & Submit Quote</a>
        </div>
      </div>
      <div class="footer">
        <p>© {{year}} {{appName}}. All rights reserved.</p>
        <p><a href="{{appUrl}}">Visit Website</a> • <a href="mailto:{{supportEmail}}">Contact Support</a></p>
      </div>
    </div>
  </div>
</body>
</html>

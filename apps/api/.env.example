# Database (Neon Serverless Postgres)
# For pooled connections (recommended for app):
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=15&connect_timeout=15&pool_timeout=15"
# For direct connections (migrations, schema changes — use NON-pooler endpoint):
DIRECT_DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require&connect_timeout=15"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Server
PORT=4000
NODE_ENV="development"

# Payment Gateways (for Nepal)
ESEWA_MERCHANT_ID=""
ESEWA_SECRET=""
KHALTI_PUBLIC_KEY=""
KHALTI_SECRET_KEY=""

# Payment Gateways (for India)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (Hostinger SMTP)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="587"
SMTP_USER="admin@orivraa.com"
SMTP_PASS="your-email-password"
# Available sender identities:
# - noreply@orivraa.com (transactional emails)
# - orders@orivraa.com (order notifications)
# - admin@orivraa.com (admin alerts)
# - support@orivraa.com (support emails)

# App URL (for email links)
APP_URL="https://www.orivraa.com"

# SMS (Sparrow SMS for Nepal)
SPARROW_SMS_TOKEN=""
SPARROW_SMS_FROM=""

# Market Rates (MetalpriceAPI)
METALPRICEAPI_KEY=""
METALPRICEAPI_BASE_URL="https://api.metalpriceapi.com/v1"
MARKET_RATES_CACHE_TTL_HOURS="24"

# FX Rates (Frankfurter API - free, no key required)
# These are fallback values used when all FX APIs are unavailable
# Updated Jan 2026: 1 USD = ~90 INR, ~144 NPR (ratio ~1.6)
DEFAULT_USD_INR="90"
DEFAULT_USD_NPR="144"
DEFAULT_USD_AED="3.67"
DEFAULT_USD_GBP="0.79"
DEFAULT_USD_EUR="0.92"

# Fallback gold price (USD per troy ounce) when MetalpriceAPI is unavailable
FALLBACK_GOLD_USD_OZ="2600"

# IPv4-first DNS (helps with ENOTFOUND errors on Windows/WSL)
# Set to "true" if experiencing DNS resolution failures
PREFER_IPV4="false"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# AI Image Generation (Google Gemini/Imagen)
GEMINI_API_KEY=""

# Frontend URL (for OAuth redirects)
FRONTEND_URL="http://localhost:3000"

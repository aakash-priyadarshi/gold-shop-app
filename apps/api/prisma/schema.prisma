  DIAMOND_NATURAL
  DIAMOND_LAB
  MOISSANITE
  CUBIC_ZIRCONIA
  RUBY
  SAPPHIRE
  EMERALD
  PEARL
  AMETHYST
  TOPAZ
  GARNET
  OPAL
  TURQUOISE
  AQUAMARINE
  PERIDOT
  CITRINE
  OTHER
}

enum GemstoneShape {
  ROUND
  OVAL
  PRINCESS
  CUSHION
  EMERALD_CUT
  MARQUISE
  PEAR
  HEART
  RADIANT
  ASSCHER
  BAGUETTE
  TRILLION
  CABOCHON
}

enum SettingStyle {
  PRONG
  BEZEL
  CHANNEL
  PAVE
  FLUSH
  TENSION
  HALO
  CLUSTER
  BAR
  INVISIBLE
}

model GemstonePreset {
  id              String        @id @default(uuid())
  
  // Basic info
  nameEn          String
  nameNe          String?
  nameHi          String?
  
  stoneType       GemstoneType
  shape           GemstoneShape
  settingStyle    SettingStyle
  
  // Size options
  sizeOptions     Json          // Array of {label, sizeMm, caratWeight, priceNpr}
  
  // Color options for this preset
  colorOptions    String[]      // ["D", "E", "F"] for diamonds, ["Red", "Pink"] for rubies, etc.
  
  // Default count
  defaultCount    Int           @default(1)
  
  // Image for reference
  imageUrl        String?
  
  // Linked to template (optional - can be general)
  templateId      String?
  template        JewelleryTemplate? @relation(fields: [templateId], references: [id])
  
  // Base price per stone (for estimate)
  basePriceNpr    Float
  
  isActive        Boolean       @default(true)

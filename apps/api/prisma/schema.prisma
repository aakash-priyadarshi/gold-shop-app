generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                   String                  @id @default(uuid())
  email                String                  @unique
  phone                String?                 @unique
  passwordHash         String
  googleId             String?                 @unique
  role                 UserRole
  status               UserStatus              @default(PENDING_VERIFICATION)
  firstName            String
  lastName             String
  preferredLanguage    String                  @default("en")
  preferredCurrency    CurrencyCode            @default(NPR)
  preferredCountry     String                  @default("US")
  preferredState       String?
  preferredCity        String?
  themeMode            String                  @default("system")
  emailVerified        Boolean                 @default(false)
  emailVerifiedAt      DateTime?
  phoneVerifiedAt      DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  lastLoginAt          DateTime?
  // Multi-shop support
  activeShopId         String?
  // 2FA support
  twoFactorEnabled     Boolean                 @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]
  apiTokens            ApiToken[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  customerOrders       Order[]                 @relation("CustomerOrders")
  refreshTokens        RefreshToken[]
  reportsAgainst       Report[]                @relation("ReportReported")
  reportsFiled         Report[]                @relation("ReportReporter")
  rfqRequests          RfqRequest[]            @relation("CustomerRfqs")
  shops                Shop[]
  verificationRequests VerificationRequest[]   @relation("UserVerificationRequests")
  purchaseStats        CustomerPurchaseStats[]
  // Design gallery
  designs              Design[]                @relation("DesignCreator")
  designLikes          DesignLike[]
  // Delivery addresses
  deliveryAddresses    CustomerAddress[]
  // CRM notes
  customerNotes        CustomerNote[]     @relation("CustomerNotes")
  authoredNotes        CustomerNote[]     @relation("AuthoredNotes")
  // Chat
  sentMessages         Message[]          @relation("MessageSender")
  buyerConversations   Conversation[]     @relation("BuyerConversations")
  // Support Tickets
  supportTickets       SupportTicket[]    @relation("UserTickets")
  assignedTickets      SupportTicket[]    @relation("AssignedTickets")
  ticketMessages       TicketMessage[]    @relation("TicketMessageSender")
  // POS / Wishlist
  wishlistItems        WishlistItem[]
  // AI Credits
  aiCreditsBalance     Int                 @default(0)
  aiCreditsGrantedAt   DateTime?
  aiCreditLedger       AiCreditLedger[]
  // Enterprise staff
  staffAccounts        StaffAccount[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([activeShopId])
}

// Customer delivery addresses
model CustomerAddress {
  id          String   @id @default(uuid())
  userId      String
  label       String   @default("Home") // Home, Work, Other
  fullName    String
  phone       String
  addressLine1 String
  addressLine2 String?
  city        String
  state       String
  postalCode  String
  country     String   @default("IN")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

// Track customer purchase statistics by currency
model CustomerPurchaseStats {
  id          String       @id @default(uuid())
  customerId  String
  currency    CurrencyCode
  orderCount  Int          @default(0)
  totalSpent  Float        @default(0)
  lastOrderAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, currency])
  @@index([customerId])
  @@index([currency])
}

// CRM: Notes about customers added by shop staff
model CustomerNote {
  id         String   @id @default(uuid())
  customerId String   // User ID of the customer
  shopId     String?  // Which shop's staff added this note (null for admin notes)
  authorId   String   // User ID of the shop staff or admin who wrote it
  note       String
  category   String   @default("GENERAL") // GENERAL, PREFERENCE, FOLLOW_UP, COMPLAINT, VIP
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User  @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)
  shop     Shop? @relation("ShopCustomerNotes", fields: [shopId], references: [id], onDelete: Cascade)
  author   User  @relation("AuthoredNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([shopId])
  @@index([customerId, shopId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model ApiToken {
  id                 String    @id @default(uuid())
  userId             String
  name               String
  tokenHash          String    @unique
  tokenPrefix        String
  scopes             String[]  @default([])
  expiresAt          DateTime
  lastUsedAt         DateTime?
  revokedAt          DateTime?
  createdAt          DateTime  @default(now())
  encryptedToken     String?
  tokenViewableUntil DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([tokenPrefix])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Shop {
  id                      String                @id @default(uuid())
  userId                  String
  shopName                String
  shopNameNe              String?
  shopNameHi              String?
  slug                    String?               @unique
  description             String?
  descriptionNe           String?
  descriptionHi           String?
  about                   String?               // Moderated about section (no contacts allowed)
  profileImage            String?               // Shop profile picture URL
  coverImage              String?               // Shop cover/banner image URL
  country                 String                @default("NP")
  state                   String?
  city                    String
  address                 String
  pincode                 String?
  latitude                Float?
  longitude               Float?
  contactPhone            String
  contactEmail            String?
  whatsappNumber          String?
  isVerified              Boolean               @default(false)
  verificationDocuments   Json?
  bisLicenseNumber        String?
  panNumber               String?
  vatNumber               String?
  supportedJewelleryTypes String[]
  supportedMethods        String[]
  supportedMaterials      String[]
  supportedGemstones      String[]
  supportedFinishes       String[]
  supportedAlloys         String[]              // e.g. ["GOLD_18K", "GOLD_14K", "STERLING_SILVER_925"]
  supportedBaseMetals     String[]              // e.g. ["BRASS", "COPPER", "STAINLESS_STEEL_316L"]
  supportedPlatingTypes   String[]              // e.g. ["GOLD_PLATING", "RHODIUM_PLATING", "PVD_COATING"]
  minOrderValueNpr        Float                 @default(0)
  maxOrderValueNpr        Float?
  maxWeightGrams          Float?
  acceptsComplexOrders    Boolean               @default(true)
  codEnabled              Boolean               @default(false)
  codMaxValueNpr          Float?
  bankAccountDetails      Json?
  makingChargePercent     Float                 @default(10)
  nickelCompliantFlag     Boolean               @default(false)
  isActive                Boolean               @default(true)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  holdAt                  DateTime?
  holdReason              String?
  isOnHold                Boolean               @default(false)
  lastComplianceCheckAt   DateTime?

  // Seller tier & performance fields
  sellerTier              SellerTier            @default(STANDARD)
  tierUnlockedAt          DateTime?
  tierLockedReason        String?
  eliteFastTracked        Boolean               @default(false)
  makingChargeCap         Float                 @default(15)  // Dynamic cap per tier
  suspendedAt             DateTime?
  suspensionCount         Int                   @default(0)
  disputeCount            Int                   @default(0)
  firstSaleAt             DateTime?

  commissionLedgers       CommissionLedger[]
  inventoryItems          InventoryItem[]
  orders                  Order[]
  rfqOffers               RfqOffer[]
  shopQuotes              ShopQuote[]
  walkInCustomers         WalkInCustomer[]
  user                    User                  @relation(fields: [userId], references: [id])
  finishPricing           ShopFinishPricing[]
  gemstoneRates           ShopGemstoneRate[]
  metalRates              ShopMetalRate[]
  priceOverrides          ShopPriceOverride[]
  ratings                 ShopRating[]
  verificationRequests    VerificationRequest[] @relation("ShopVerificationRequests")
  performance             SellerPerformance?
  badges                  SellerBadge[]
  invoices                Invoice[]
  invoiceSettings         InvoiceSettings?
  customerNotes           CustomerNote[]       @relation("ShopCustomerNotes")
  conversations           Conversation[]       @relation("ShopConversations")
  catalogues              Catalogue[]
  walkInRfqs              RfqRequest[]         @relation("ShopWalkInRfqs")
  showroomSessions        ShowroomSession[]
  posSessions             PosSession[]
  stockReservations       StockReservation[]
  subscriptions           SellerSubscription[]
  // Enterprise features
  branches                ShopBranch[]
  staffAccounts           StaffAccount[]
  apiKeys                 ShopApiKey[]
  webhookSubscriptions    WebhookSubscription[]
  whiteLabelConfig        WhiteLabelConfig?
  scheduledReports        ScheduledReport[]
  bulkImportJobs          BulkImportJob[]
  demandForecasts         DemandForecast[]
  repricingRules          RepricingRule[]

  @@index([userId])
  @@index([country, city])
  @@index([isActive, isVerified])
  @@index([sellerTier])
}

model ShopMetalRate {
  id             String   @id @default(uuid())
  shopId         String
  metalType      String
  ratePerGramNpr Float
  lastUpdatedAt  DateTime @default(now())
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, metalType])
  @@index([shopId])
}

model ShopFinishPricing {
  id         String @id @default(uuid())
  shopId     String
  finishType String
  tier       String
  priceNpr   Float
  shop       Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, finishType, tier])
  @@index([shopId])
}

model ShopGemstoneRate {
  id            String   @id @default(uuid())
  shopId        String
  stoneType     String   // e.g. DIAMOND, RUBY, EMERALD, SAPPHIRE, etc.
  origin        String   @default("NATURAL") // NATURAL or LAB_GROWN
  sizeCategory  String   // e.g. "0.1-0.25", "0.25-0.5", "0.5-1", "1-2" (carat ranges)
  qualityTier   String   @default("MEDIUM") // LOW, MEDIUM, HIGH, PREMIUM
  pricePerStone Float    // NPR per stone
  lastUpdatedAt DateTime @default(now())
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, stoneType, origin, sizeCategory, qualityTier])
  @@index([shopId])
}

model Material {
  id               String           @id @default(uuid())
  code             String           @unique
  category         MaterialCategory
  nameEn           String
  nameNe           String?
  nameHi           String?
  descriptionEn    String?
  descriptionNe    String?
  descriptionHi    String?
  purity           Float?
  allowedMethods   String[]
  complianceFlags  String[]
  baseUnit         String           @default("gram")
  marketRateNpr    Float?
  lastMarketUpdate DateTime?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([category])
  @@index([code])
}

model InventoryItem {
  id               String          @id @default(uuid())
  shopId           String
  sku              String          @unique
  jewelleryType    JewelleryType
  nameEn           String
  nameNe           String?
  nameHi           String?
  descriptionEn    String?
  descriptionNe    String?
  descriptionHi    String?
  buildMethod      String
  composition      Json
  totalWeightGrams Float
  dimensions       Json?
  gemstones        Json?
  metalValueNpr    Float
  makingChargeNpr  Float
  gemstoneValueNpr Float           @default(0)
  taxNpr           Float           @default(0)
  totalPriceNpr    Float
  images           String[]
  videos           String[]
  certificateUrl   String?
  hallmarkNumber   String?
  hallmarkDate     DateTime?
  purityCertUrl    String?
  labels           String[]
  status           InventoryStatus @default(AVAILABLE)
  stockQuantity    Int             @default(1)
  hasSizes         Boolean             @default(false)
  visibility       InventoryVisibility @default(PUBLIC)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  shop              Shop                @relation(fields: [shopId], references: [id])
  variants          ProductVariant[]
  catalogueItems    CatalogueItem[]
  wishlistItems     WishlistItem[]
  posSessionItems   PosSessionItem[]
  stockReservations StockReservation[]

  @@index([shopId, status])
  @@index([jewelleryType])
  @@index([buildMethod])
  @@index([visibility])
}

// Product size variants (rings, bracelets, etc.)
model ProductVariant {
  id              String        @id @default(uuid())
  inventoryItemId String
  sizeLabel       String        // e.g. "US 7", "UK O", "16.5 cm"
  sizeSystem      String        @default("US") // US, UK, EU, MM
  sizeValue       Float?        // numeric value for sorting (e.g. 7.0)
  sku             String        @unique
  stock           Int           @default(0)
  priceOverride   Float?        // optional price override for this variant
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  posSessionItems  PosSessionItem[]
  stockReservations StockReservation[]

  @@unique([inventoryItemId, sizeLabel])
  @@index([inventoryItemId])
  @@index([sku])
}

model RfqRequest {
  id                    String          @id @default(uuid())
  customerId            String? // Optional for walk-in customers
  jewelleryType         JewelleryType
  buildMethod           BuildMethod
  templateId            String?
  weightCategory        WeightCategory?
  composition           Json
  surfaceFinish         String?
  addGoldPlating        Boolean         @default(false)
  platingType           String?
  platingTier           String?
  designId              String? // Link to Design Gallery if created via "Build This"
  targetTotalWeightG    Float?
  targetGoldWeightG     Float?
  budgetMinNpr          Float?
  budgetMaxNpr          Float?
  preferredDeliveryDays Int?
  specialInstructions   String?
  referenceImages       String[]
  estimatedPriceMinNpr  Float?
  estimatedPriceMaxNpr  Float?
  broadcastSnapshot     Json?
  broadcastAt           DateTime?
  status                RfqStatus       @default(DRAFT)
  expiresAt             DateTime?
  selectedOfferId       String?         @unique
  mandatoryLabels       String[]
  // Walk-in RFQ support
  source                RfqSource       @default(ONLINE)
  createdByShopId       String?         // Shop that created this walk-in RFQ
  walkInMeta            Json?           // { customerName?, customerPhone?, customerNotes?, catalogueSlug?, items, measurements?, budgetMin?, budgetMax?, deadlineDays? }
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  gemstones     RfqGemstone[]
  offers        RfqOffer[]
  customer      User?           @relation("CustomerRfqs", fields: [customerId], references: [id])
  selectedOffer RfqOffer?       @relation("SelectedOffer", fields: [selectedOfferId], references: [id])
  targetedShops RfqShopTarget[]
  design        Design?         @relation(fields: [designId], references: [id])
  createdByShop Shop?           @relation("ShopWalkInRfqs", fields: [createdByShopId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([designId])
  @@index([source, createdAt])
  @@index([createdByShopId, createdAt])
}

model RfqGemstone {
  id                String     @id @default(uuid())
  rfqId             String
  stoneType         String
  shape             String
  sizeMm            Float?
  caratWeight       Float?
  color             String?
  clarity           String?
  settingStyle      String?
  count             Int        @default(1)
  position          String?
  estimatedPriceNpr Float?
  createdAt         DateTime   @default(now())
  rfq               RfqRequest @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
}

model RfqShopTarget {
  id          String     @id @default(uuid())
  rfqId       String
  shopId      String
  sentAt      DateTime   @default(now())
  viewedAt    DateTime?
  respondedAt DateTime?
  rfq         RfqRequest @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@unique([rfqId, shopId])
  @@index([shopId])
}

model RfqOffer {
  id                    String      @id @default(uuid())
  rfqId                 String
  shopId                String
  offerType             String
  declineReason         String?
  confirmedComposition  Json
  confirmedTotalWeightG Float?
  confirmedGoldWeightG  Float?
  metalCostNpr          Float
  makingChargeNpr       Float
  finishCostNpr         Float       @default(0)
  gemstoneCostNpr       Float       @default(0)
  taxNpr                Float       @default(0)
  totalPriceNpr         Float
  estimatedDays         Int
  productionStartDate   DateTime?
  bookingFeeNpr         Float
  bookingFeePercent     Float
  paymentDeadline       DateTime?
  shopNotes             String?
  status                OfferStatus @default(PENDING)
  parentOfferId         String?
  // Win/Loss tracking (Sprint 3)
  lossReasonCategory    String?     // PRICE_TOO_HIGH, SLOW_DELIVERY, LOW_TRUST, BETTER_OFFER, OTHER
  lossReasonNote        String?     // Free-text explanation
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  parentOffer           RfqOffer?   @relation("OfferChain", fields: [parentOfferId], references: [id])
  counterOffers         RfqOffer[]  @relation("OfferChain")
  rfq                   RfqRequest  @relation(fields: [rfqId], references: [id])
  shop                  Shop        @relation(fields: [shopId], references: [id])
  selectedByRfq         RfqRequest? @relation("SelectedOffer")

  @@index([rfqId])
  @@index([shopId])
  @@index([status])
}

// Walk-in customer model - for customers who visit the shop in person
// Phone number is the unique identifier for returning customers
model WalkInCustomer {
  id               String      @id @default(uuid())
  phone            String      @unique // Unique identifier - phone is used for lookup
  phoneCountryCode String      @default("+91")
  name             String
  email            String?
  address          String
  city             String
  country          String      @default("India")
  createdByShopId  String      // First shop that created this customer
  notes            String?     // Any notes about the customer
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  createdByShop    Shop        @relation(fields: [createdByShopId], references: [id])
  shopQuotes       ShopQuote[]

  @@index([phone])
  @@index([createdByShopId])
}

// Shop Quote model - for walk-in customer orders
// Separate from RfqRequest for cleaner workflow
model ShopQuote {
  id                    String           @id @default(uuid())
  quoteNumber           String           @unique // SQ-XXXXXX
  shopId                String
  walkInCustomerId      String

  // Jewellery details (same as RFQ)
  jewelleryType         JewelleryType
  buildMethod           BuildMethod
  composition           Json
  targetTotalWeightG    Float?
  targetGoldWeightG     Float?
  specialInstructions   String?
  referenceImages       String[]

  // Pricing (calculated by shopkeeper)
  metalCostNpr          Float?
  makingChargeNpr       Float?
  gemstoneCostNpr       Float            @default(0)
  finishCostNpr         Float            @default(0)
  taxNpr                Float            @default(0)
  totalPriceNpr         Float?
  goldPriceSnapshot     Float?           // Gold rate at time of quote
  estimatedDays         Int?

  // Status: QUOTED → CONFIRMED → IN_PROGRESS → READY → COMPLETED / CANCELLED
  status                ShopQuoteStatus  @default(QUOTED)
  confirmedAt           DateTime?
  startedAt             DateTime?
  readyAt               DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancelReason          String?

  // Payment (always at shop)
  advancePaidNpr        Float            @default(0)
  balanceDueNpr         Float?
  paidInFullAt          DateTime?

  // Metadata
  shopNotes             String?          // Internal notes for shopkeeper
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  shop                  Shop             @relation(fields: [shopId], references: [id])
  walkInCustomer        WalkInCustomer   @relation(fields: [walkInCustomerId], references: [id])

  @@index([shopId])
  @@index([walkInCustomerId])
  @@index([status])
  @@index([quoteNumber])
}

enum ShopQuoteStatus {
  QUOTED      // Initial quote created
  CONFIRMED   // Customer agreed, work can start
  IN_PROGRESS // Manufacturing in progress
  READY       // Ready for pickup
  COMPLETED   // Delivered and fully paid
  CANCELLED   // Cancelled by customer or shop
}

model Order {
  id                     String              @id @default(uuid())
  orderNumber            String              @unique
  orderType              OrderType
  customerId             String
  shopId                 String
  inventoryItemId        String?
  rfqOfferId             String?
  productSnapshot        Json
  subtotalNpr            Float
  taxNpr                 Float
  shippingNpr            Float               @default(0)
  discountNpr            Float               @default(0)
  totalNpr               Float
  paymentMethod          String?
  paymentStatus          String
  bookingFeePaidNpr      Float?
  balanceDueNpr          Float
  shippingAddress        Json
  shippingMethod         String?
  trackingNumber         String?
  estimatedDelivery      DateTime?
  actualDelivery         DateTime?
  status                 OrderStatus         @default(CREATED)
  bookingExpiresAt       DateTime?
  createdByAdmin         Boolean             @default(false)
  adminNotes             String?
  paymentVerifiedByAdmin Boolean             @default(false)
  paymentVerifiedAt      DateTime?
  paymentVerifiedById    String?
  currentVersionId       String?             @unique
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  detailedStatus         DetailedOrderStatus @default(PLACED)
  displayCurrency        CurrencyCode        @default(NPR)
  marketCountry          MarketRegion        @default(NP)
  paidAtShopConfirmed    Boolean             @default(false)
  paidAtShopConfirmedAt  DateTime?
  paidAtShopRequested    Boolean             @default(false)
  paidAtShopRequestedAt  DateTime?
  paymentMethodEnum      PaymentMethod?
  paymentStatusEnum      PaymentStatusEnum   @default(UNPAID)
  // Refund fields
  refundStatus           RefundStatus?
  refundableAmount       Float?
  refundReason           String?
  refundRequestedAt      DateTime?
  refundProcessedAt      DateTime?
  refundProcessedById    String?
  refundIdempotencyKey   String?             @unique
  // Variant reference (for sized products)
  variantId              String?
  commissionLedger       CommissionLedger?
  customer               User                @relation("CustomerOrders", fields: [customerId], references: [id])
  shop                   Shop                @relation(fields: [shopId], references: [id])
  milestones             OrderMilestone[]
  versions               OrderVersion[]
  conversation           Conversation?

  @@index([customerId])
  @@index([shopId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdByAdmin])
  @@index([paymentVerifiedByAdmin])
  @@index([marketCountry])
  @@index([detailedStatus])
}

model OrderVersion {
  id               String             @id @default(uuid())
  orderId          String
  versionNumber    Int
  createdByRole    String
  createdById      String
  productSnapshot  Json
  subtotalNpr      Float
  taxNpr           Float
  shippingNpr      Float
  discountNpr      Float
  totalNpr         Float
  makingChargesNpr Float?
  materials        Json?
  gemstones        Json?
  finishes         Json?
  timeline         Json?
  status           OrderVersionStatus @default(PENDING)
  customerResponse String?
  customerNotes    String?
  respondedAt      DateTime?
  changeSummary    String?
  createdAt        DateTime           @default(now())
  order            Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, versionNumber])
  @@index([orderId])
  @@index([status])
}

model OrderMilestone {
  id           String        @id @default(uuid())
  orderId      String
  type         MilestoneType
  title        String
  description  String?
  actorType    String
  actorId      String?
  evidenceUrls String[]
  notes        String?
  completedAt  DateTime      @default(now())
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id               String        @id @default(uuid())
  orderId          String
  amountNpr        Float
  currency         String        @default("NPR")
  paymentGateway   String
  gatewayPaymentId String?
  gatewayOrderId   String?
  status           PaymentStatus @default(PENDING)
  metadata         Json?
  failureReason    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  completedAt      DateTime?

  @@index([orderId])
  @@index([gatewayPaymentId])
}

model ShopRating {
  id            String   @id @default(uuid())
  shopId        String
  customerId    String
  orderId       String   @unique
  overall       Int
  quality       Int?
  communication Int?
  delivery      Int?
  accuracy      Int?
  reviewText    String?
  isPublic      Boolean  @default(true)
  createdAt     DateTime @default(now())
  shop          Shop     @relation(fields: [shopId], references: [id])

  // Seller reply
  sellerReply   String?

model Invoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   @unique
  shopId          String
  orderId         String?
  shopQuoteId     String?

  // Customer details (denormalized for PDF generation)
  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Financial
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  taxRate         Float    @default(0)
  taxLabel        String?
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balanceDue      Float    @default(0)
  currency        String   @default("NPR")

  // Line items as JSON array
  // Each: { label, category, quantity, unitPrice, amount, details? }
  lineItems       Json     @default("[]")

  // Status
  status          String   @default("DRAFT")  // DRAFT, ISSUED, PAID, PARTIALLY_PAID, OVERDUE, VOID, CANCELLED
  paymentStatus   String   @default("UNPAID") // UNPAID, PARTIALLY_PAID, PAID

  // Dates
  issuedAt        DateTime?
  dueDate         DateTime?
  paidAt          DateTime?
  voidedAt        DateTime?

  notes           String?
  terms           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop            Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([orderId])
  @@index([status])
  @@index([invoiceNumber])
}

// ═══════════════════════════════════════════
// INVOICE & BILLING
// ═══════════════════════════════════════════

model Invoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   @unique
  shopId          String
  orderId         String?
  shopQuoteId     String?

  // Customer details (denormalized for PDF generation)
  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Financial
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  taxRate         Float    @default(0)
  taxLabel        String?
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balanceDue      Float    @default(0)
  currency        String   @default("NPR")

  // Line items as JSON array
  // Each: { label, category, quantity, unitPrice, amount, details? }
  lineItems       Json     @default("[]")

  // Status
  status          String   @default("DRAFT")  // DRAFT, ISSUED, PAID, PARTIALLY_PAID, OVERDUE, VOID, CANCELLED
  paymentStatus   String   @default("UNPAID") // UNPAID, PARTIALLY_PAID, PAID

  // Dates
  issuedAt        DateTime?
  dueDate         DateTime?
  paidAt          DateTime?
  voidedAt        DateTime?

  notes           String?
  terms           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop            Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([orderId])
  @@index([status])
  @@index([invoiceNumber])
}

model InvoiceSettings {
  id              String   @id @default(uuid())
  shopId          String   @unique

  // Branding
  shopNameOnBill  String?          // Custom name to print on invoice (overrides shop.shopName)
  shopLogoUrl     String?          // Logo/icon URL for the bill
  tagline         String?          // e.g. "Trusted since 1990"

  // Contact & legal
  shopAddress     String?          // Address to show on bill
  shopPhone       String?          // Phone to show on bill
  shopEmail       String?          // Email to show on bill
  gstin           String?          // GST / VAT / PAN number
  licenseNumber   String?          // BIS / Hallmark license
  footerNote      String?          // Custom footer text (e.g. "Thank you for your business")
  termsText       String?          // Default terms & conditions

  // Per-field position: each field can be TOP or BOTTOM independently
  shopNamePosition  String  @default("TOP")
  logoPosition      String  @default("TOP")
  taglinePosition   String  @default("TOP")
  addressPosition   String  @default("TOP")
  phonePosition     String  @default("TOP")
  emailPosition     String  @default("TOP")
  gstinPosition     String  @default("TOP")
  licensePosition   String  @default("TOP")
  footerPosition    String  @default("BOTTOM")
  termsPosition     String  @default("BOTTOM")

  // Visibility toggles
  showLogo        Boolean  @default(true)
  showAddress     Boolean  @default(true)
  showPhone       Boolean  @default(true)
  showEmail       Boolean  @default(false)
  showGstin       Boolean  @default(true)
  showLicense     Boolean  @default(false)
  showFooter      Boolean  @default(true)
  showTerms       Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════
// MARKETPLACE INTELLIGENCE & AI DATA CAPTURE
// ═══════════════════════════════════════════

// Captures data from every RFQ→Offer→Order cycle for AI training
model RfqOrderInsight {
  id                 String   @id @default(uuid())
  rfqId              String
  rfqJewelleryType   String
  rfqBuildMethod     String
  rfqComposition     Json
  rfqBudgetMin       Float?
  rfqBudgetMax       Float?
  rfqWeightCategory  String?
  rfqSpecialNotes    String?
  rfqMarketRegion    String?

  // Offer aggregates
  totalOffers        Int      @default(0)
  avgOfferPrice      Float?
  minOfferPrice      Float?
  maxOfferPrice      Float?
  avgMakingChargePct Float?
  avgEstimatedDays   Int?

  // Outcome
  selectedOfferId    String?
  selectedShopId     String?
  selectedPrice      Float?
  orderId            String?
  orderCompleted     Boolean  @default(false)
  orderRating        Int?

  // Loss analysis
  lossReasons        Json?    // [{ offerId, reason, category }]

  // Timing metrics
  rfqCreatedAt       DateTime
  firstOfferAt       DateTime?
  offerSelectedAt    DateTime?
  orderCompletedAt   DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([rfqJewelleryType])
  @@index([rfqBuildMethod])
  @@index([selectedShopId])
  @@index([orderCompleted])
  @@index([rfqCreatedAt])
  @@index([rfqMarketRegion])
}

// Tracks AI phase milestones and admin alerts
model AiPhaseMilestone {
  id              String    @id @default(uuid())
  phase           Int       // 1, 2, 3
  milestoneName   String    // e.g. "PHASE_1_LAUNCH", "100_ORDERS", "500_ORDERS"
  description     String?   // Human-readable description of what this enables
  thresholdValue  Int       // 0, 100, 200, 500
  currentValue    Int       @default(0)
  isReached       Boolean   @default(false)
  reachedAt       DateTime?
  adminNotifiedAt DateTime?
  actionItems     Json?     // [{ action, status, completedAt }]
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([phase, milestoneName])
  @@index([isReached])
  @@index([phase])
}

// Quote anomaly detection results
model QuoteAnomaly {
  id              String   @id @default(uuid())
  offerId         String
  shopId          String
  rfqId           String
  anomalyType     String   // PRICE_TOO_HIGH, PRICE_TOO_LOW, MAKING_CHARGE_SPIKE, DELIVERY_OUTLIER
  severity        String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  expectedValue   Float    // What the average/median was
  actualValue     Float    // What this offer had
  deviationPct    Float    // How far off from expected
  isReviewed      Boolean  @default(false)
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewNote      String?
  createdAt       DateTime @default(now())

  @@index([shopId])
  @@index([anomalyType])
  @@index([isReviewed])
  @@index([severity])
  @@index([createdAt])
}

// ═══════════════════════════════════════════
// IN-APP CHAT SYSTEM (Anti-Circumvention)
// ═══════════════════════════════════════════

model Conversation {
  id              String             @id @default(uuid())
  orderId         String?            @unique
  rfqId           String?
  buyerId         String
  shopId          String
  status          ConversationStatus @default(ACTIVE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  messages        Message[]
  buyer           User               @relation("BuyerConversations", fields: [buyerId], references: [id])
  shop            Shop               @relation("ShopConversations", fields: [shopId], references: [id])
  order           Order?             @relation(fields: [orderId], references: [id])

  @@index([buyerId])
  @@index([shopId])
  @@index([orderId])
  @@index([rfqId])
  @@index([status])
}

model Message {
  id               String       @id @default(uuid())
  conversationId   String
  senderId         String
  senderRole       String       // CUSTOMER, SHOPKEEPER, SUPPORT, ADMIN
  content          String
  maskedContent    String?      // Content after masking PII
  hasViolation     Boolean      @default(false)
  violationType    String?      // PHONE, EMAIL, WHATSAPP, TELEGRAM, INSTAGRAM, CONTACT_PHRASE
  attachmentUrl    String?      // R2 image/file URL
  attachmentType   String?      // image, document
  messageType      MessageType  @default(TEXT)
  payload          Json?        // Structured payload for PRODUCT_CARD, CATALOGUE_LINK, etc.
  isSystemGenerated Boolean     @default(false) // System-generated messages bypass PII scanning
  isRead           Boolean      @default(false)
  readAt           DateTime?
  isSystem         Boolean      @default(false) // System-generated messages (warnings, etc.)
  isBlocked        Boolean      @default(false) // Blocked by moderation — not delivered to recipient
  createdAt        DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([conversationId, createdAt])
}

// ═══════════════════════════════════════════
// RING / JEWELLERY SIZE CONFIG (Per-Market)
// ═══════════════════════════════════════════

model SizeChart {
  id           String       @id @default(uuid())
  jewelleryType JewelleryType
  sizeSystem   String       // US, UK, EU, MM
  region       MarketRegion
  sizeLabel    String       // "7", "O", "55", "17.3mm"
  sizeValue    Float        // numeric sort value
  diameterMm   Float?       // inner diameter in mm
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  @@unique([jewelleryType, sizeSystem, region, sizeLabel])
  @@index([jewelleryType, region])
}

enum ConversationStatus {
  ACTIVE
  LOCKED       // Locked due to violations
  ARCHIVED     // Completed / closed
}

enum RefundStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

// ═══════════════════════════════════════════
// SUPPORT TICKET SYSTEM
// ═══════════════════════════════════════════

model SupportTicket {
  id              String         @id @default(uuid())
  ticketNumber    String         @unique // e.g. TKT-00001
  userId          String?        // null for guest tickets (from public help page)
  guestEmail      String?        // for non-logged-in users
  guestName       String?        // for non-logged-in users
  type            TicketType
  subject         String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)

  // Assignment
  assigneeId      String?        // support/admin who claimed this
  claimedAt       DateTime?

  // Context (optional references)
  orderId         String?        // related order
  conversationId  String?        // related chat conversation

  // Resolution
  resolvedAt      DateTime?
  closedAt        DateTime?
  resolutionNote  String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  user            User?          @relation("UserTickets", fields: [userId], references: [id])
  assignee        User?          @relation("AssignedTickets", fields: [assigneeId], references: [id])
  messages        TicketMessage[]

  @@index([userId])
  @@index([assigneeId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@index([ticketNumber])
}

model TicketMessage {
  id              String   @id @default(uuid())
  ticketId        String
  senderId        String?  // null for system messages or guest messages
  senderRole      String   // CUSTOMER, SHOPKEEPER, SUPPORT, ADMIN, SYSTEM, GUEST, AI_BOT
  senderName      String?  // display name (for guests or bot)
  content         String
  attachmentUrl   String?
  attachmentType  String?  // image, document, video
  isInternal      Boolean  @default(false) // internal notes visible only to support/admin
  createdAt       DateTime @default(now())

  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender          User?         @relation("TicketMessageSender", fields: [senderId], references: [id])

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
  @@index([ticketId, createdAt])
}

// ============================================

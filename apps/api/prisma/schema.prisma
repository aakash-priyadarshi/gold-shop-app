  PLATFORM_BUG        // technical issue
  FEATURE_REQUEST     // feature suggestion
  KYC_VERIFICATION    // KYC help
  OTHER               // general inquiry
}

enum TicketStatus {
  OPEN          // newly created, unclaimed
  CLAIMED       // claimed by support/admin
  IN_PROGRESS   // being worked on
  WAITING_USER  // waiting for user response

// ══════════════════════════════════════
// PRICING ENGINE CONFIGURATION TABLES
// ══════════════════════════════════════

// System-level pricing configuration with versioning
model SystemPriceConfig {
  id              String    @id @default(uuid())
  version         Int       @default(1)
  configType      String    // 'METAL_PURITY', 'BASE_METAL', 'FINISH', 'GEMSTONE', 'SETTING', 'TAX'
  configKey       String    // e.g., 'GOLD_24K', 'BRASS', 'GOLD_PLATING_STANDARD'
  configData      Json      // Flexible config data
  isActive        Boolean   @default(true)
  effectiveFrom   DateTime  @default(now())
  effectiveUntil  DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([configType, configKey])
  @@index([isActive, effectiveFrom])
}

// Market adjustment configuration by region
model MarketAdjustmentConfig {
  id              String    @id @default(uuid())
  marketRegion    MarketRegion
  category        String    // 'PRECIOUS_METAL', 'BASE_METAL', 'GEMSTONE', 'FINISH', 'ALL'
  adjustmentType  String    // 'MULTIPLIER', 'FIXED_ADDON', 'PERCENTAGE'
  adjustmentValue Float
  description     String?
  isActive        Boolean   @default(true)
  effectiveFrom   DateTime  @default(now())
  effectiveUntil  DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([marketRegion])
  @@index([marketRegion, category, isActive])
}

// Tax rules configuration per market/category
model TaxRuleConfig {
  id              String       @id @default(uuid())
  marketRegion    MarketRegion
  taxType         String       // 'GST', 'VAT', 'SALES_TAX'
  taxName         String       // Display name: "GST (3%)", "VAT (13%)"
  category        String       // 'PRECIOUS_METAL', 'MAKING_CHARGE', 'GEMSTONE', 'FINISH', 'ALL'
  rate            Float        // 0.03 for 3%
  isCompounding   Boolean      @default(false)
  priority        Int          @default(0)
  stateCode       String?      // For US state-specific taxes
  description     String?
  isActive        Boolean      @default(true)
  effectiveFrom   DateTime     @default(now())
  effectiveUntil  DateTime?
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([marketRegion, isActive])
  @@index([category])
}

// Shop-level price overrides
model ShopPriceOverride {
  id              String    @id @default(uuid())
  shopId          String
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  overrideType    String    // 'METAL_RATE', 'MAKING_CHARGE', 'FINISH', 'GEMSTONE', 'MARKUP'
  itemCode        String    // e.g., 'GOLD_24K', 'GOLD_PLATING_PREMIUM'
  overrideMode    String    // 'FIXED', 'PERCENTAGE', 'MULTIPLIER'
  overrideValue   Float
  currency        CurrencyCode @default(NPR)
  minValue        Float?    // Admin-enforced minimum
  maxValue        Float?    // Admin-enforced maximum
  isActive        Boolean   @default(true)
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shopId, overrideType, itemCode])
  @@index([shopId])
}

// Gemstone pricing configuration
model GemPriceConfig {
  id              String    @id @default(uuid())
  stoneType       String    // 'DIAMOND_NATURAL', 'DIAMOND_LAB', 'MOISSANITE', etc.
  origin          String?   // 'NATURAL', 'LAB' (for diamonds)
  qualityGrade    String    // 'A', 'B', 'C' or 'BUDGET', 'STANDARD', 'PREMIUM'
  sizeUnit        String    @default("CARAT") // 'CARAT' or 'MM'
  sizeRangeMin    Float
  sizeRangeMax    Float
  pricePerUnit    Float     // Price per carat/mm in USD
  currency        CurrencyCode @default(USD)
  source          String    @default("SYSTEM") // 'SYSTEM', 'MARKET', 'MANUAL'
  notes           String?
  isActive        Boolean   @default(true)
  effectiveFrom   DateTime  @default(now())
  effectiveUntil  DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([stoneType, qualityGrade])
  @@index([isActive])
}

// Finish pricing configuration
model FinishPriceConfig {
  id                String    @id @default(uuid())
  finishType        String    // 'GOLD_PLATING', 'VERMEIL', 'PVD', 'RHODIUM_PLATING', etc.
  tier              String    // 'LIGHT', 'STANDARD', 'PREMIUM'
  pricingModel      String    // 'FIXED', 'PERCENTAGE', 'PER_GRAM'
  basePrice         Float     // Base price in USD
  percentageUplift  Float?    // If PERCENTAGE model
  perGramRate       Float?    // If PER_GRAM model
  currency          CurrencyCode @default(USD)
  minThickness      Float?    // Microns
  maxThickness      Float?
  durabilityMonths  Int?
  notes             String?
  isActive          Boolean   @default(true)
  effectiveFrom     DateTime  @default(now())
  effectiveUntil    DateTime?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([finishType, tier])
  @@index([finishType])
}

// Base metal pricing configuration
model BaseMetalPriceConfig {
  id              String    @id @default(uuid())
  metalCode       String    @unique // 'COPPER', 'ZINC', 'NICKEL', 'BRASS', 'BRONZE', etc.
  pricePerGramUsd Float
  source          String    @default("SYSTEM") // 'SYSTEM', 'LME', 'MANUAL'
  isRestricted    Boolean   @default(false) // For Nickel compliance
  complianceNotes String?
  notes           String?
  isActive        Boolean   @default(true)
  effectiveFrom   DateTime  @default(now())
  effectiveUntil  DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
}

// Metal purity multipliers configuration
model MetalPurityConfig {
  id               String   @id @default(uuid())
  metalType        String   // 'GOLD', 'SILVER', 'PLATINUM', 'PALLADIUM'
  purityCode       String   // '24K', '22K', '18K', '14K', '10K', '999', '925', 'PT950', etc.
  purityMultiplier Float    // 1.0, 0.9167, 0.75, etc.
  displayName      String   // 'Gold 24K (Pure)', 'Gold 22K'
  description      String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([metalType, purityCode])
}

// Rounding rules per currency
model RoundingRuleConfig {
  id             String       @id @default(uuid())
  currency       CurrencyCode @unique
  roundingMode   String       // 'ROUND', 'FLOOR', 'CEIL'
  precision      Int          // 0 for no decimals, 2 for 2 decimals
  roundToNearest Float?       // e.g., 1 for nearest rupee, 0.01 for nearest cent
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Price calculation audit log for transparency
model PriceCalculationLog {
  id                String   @id @default(uuid())
  requestId         String   // Unique request identifier
  marketRegion      MarketRegion
  displayCurrency   CurrencyCode
  shopId            String?
  requestPayload    Json     // Full request
  calculationSteps  Json     // Step-by-step breakdown
  spotPricesUsed    Json?    // Spot prices at calculation time
  fxRatesUsed       Json?    // FX rates at calculation time
  marketAdjustments Json?    // Adjustments applied
  shopOverrides     Json?    // Shop overrides applied
  taxBreakdown      Json?    // Tax calculation details
  finalResult       Json     // Final pricing result
  calculationTimeMs Int?     // Time taken
  source            String   // 'PLATFORM', 'SHOP'
  createdAt         DateTime @default(now())

  @@index([requestId])
  @@index([shopId])
  @@index([createdAt])
}

// ══════════════════════════════════════
// ADMIN VERIFICATION REQUESTS & REPORTS
// ══════════════════════════════════════

model VerificationRequest {
  id          String   @id @default(uuid())
  type        String   // 'SHOP' or 'USER'
  status      String   // 'PENDING', 'APPROVED', 'REJECTED'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String?
  shop        Shop?    @relation("ShopVerificationRequests", fields: [shopId], references: [id])
  userId      String?
  user        User?    @relation("UserVerificationRequests", fields: [userId], references: [id])
  details     Json?
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  reporter    User     @relation("ReportReporter", fields: [reporterId], references: [id])
  reportedId  String?
  reported    User?    @relation("ReportReported", fields: [reportedId], references: [id])
  type        String   // e.g. 'USER', 'SHOP', 'ORDER', etc.
  reason      String
  status      String   // 'OPEN', 'RESOLVED', 'DISMISSED'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  details     Json?
}

// ══════════════════════════════════════
// OTP VERIFICATION
// ══════════════════════════════════════

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  LOGIN_2FA
}

model OtpVerification {
  id          String   @id @default(uuid())
  userId      String
  type        OtpType
  target      String   // Email or phone number
  code        String   // Hashed OTP code
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  expiresAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, type])
  @@index([target, type])
  @@index([expiresAt])
}

// ══════════════════════════════════════
// SYSTEM NOTIFICATIONS (for admin broadcast)
// ══════════════════════════════════════

model SystemNotification {
  id          String   @id @default(uuid())
  title       String
  message     String
  type        String   // 'INFO', 'WARNING', 'SUCCESS', 'ERROR'
  targetRoles String[] // Empty = all users
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([expiresAt])
}


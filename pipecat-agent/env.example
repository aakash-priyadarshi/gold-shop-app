# Google Gemini API key for LLM (from https://aistudio.google.com/)
GOOGLE_API_KEY=your_gemini_api_key

# Google service account JSON for STT (gRPC streaming requires this)
# Export from GCP Console → IAM → Service Accounts → Keys → JSON
# Paste the entire JSON content as a single line
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ElevenLabs API key (from https://elevenlabs.io/)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Deepgram API key — FALLBACK STT if Google service account is unavailable
# Sign up free at https://deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# Daily.co API key (optional for local dev, Pipecat Cloud provides this)
# DAILY_API_KEY=your_daily_api_key

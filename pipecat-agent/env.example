# Google Gemini API key for LLM (from https://aistudio.google.com/)
GOOGLE_API_KEY=your_gemini_api_key

# Google Cloud STT API key (from GCP Console — Speech-to-Text API)
GOOGLE_STT_API_KEY=your_gcp_stt_api_key

# ElevenLabs API key (from https://elevenlabs.io/)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Daily.co API key (optional for local dev, Pipecat Cloud provides this)
# DAILY_API_KEY=your_daily_api_key
